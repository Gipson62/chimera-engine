    public extern struct ecs_entity_desc_t
    {
    public:
        _canary: int32;
        id: uint64;
        parent: uint64;
        name: *uint8;
        sep: *uint8;
        root_sep: *uint8;
        symbol: *uint8;
        use_low_id: bool;
        add: *flecs::ecs_id_t;
        set: *flecs::ecs_value_t;
        add_expr: *uint8;
        fun default() -> flecs::ecs_entity_desc_t {
            return flecs::ecs_entity_desc_t {
                ._canary = 0,
                .id = 0,
                .parent = 0,
                .name = null,
                .sep = null,
                .root_sep = null,
                .symbol = null,
                .use_low_id = false,
                .add = null,
                .set = null,
                .add_expr = null
            };
        }
        fun with_name(name: *uint8) -> flecs::ecs_entity_desc_t {
            return flecs::ecs_entity_desc_t {
                ._canary = 0,
                .id = 0,
                .parent = 0,
                .name = name,
                .sep = null,
                .root_sep = null,
                .symbol = null,
                .use_low_id = false,
                .add = null,
                .set = null,
                .add_expr = null
            };
        }
    }

