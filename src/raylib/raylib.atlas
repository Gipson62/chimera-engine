namespace raylib {
    public extern struct Vector2
    {
      public:
        x: float32;
        y: float32;
        fun default() -> raylib::Vector2 {
            return raylib::Vector2 { .x = 0.0, .y = 0.0 };
        }
    }

    public extern struct Vector3
    {
      public:
        x: float32;
        y: float32;
        z: float32;
        fun default() -> raylib::Vector3 {
            return raylib::Vector3 { .x = 0.0, .y = 0.0, .z = 0.0 };
        }
    }

    public extern struct Vector4
    {
      public:
        x: float32;
        y: float32;
        z: float32;
        w: float32;
        fun default() -> raylib::Vector4 {
            return raylib::Vector4 { .x = 0.0, .y = 0.0, .z = 0.0, .w = 0.0 };
        }
    }

    public extern struct Matrix
    {
      public:
        m0:  float32;
        m4:  float32;
        m8:  float32;
        m12: float32;
        m1:  float32;
        m5:  float32;
        m9:  float32;
        m13: float32;
        m2:  float32;
        m6:  float32;
        m10: float32;
        m14: float32;
        m3:  float32;
        m7:  float32;
        m11: float32;
        m15: float32;
    }

    public extern struct Color
    {
    public:
        r: uint8;
        g: uint8;
        b: uint8;
        a: uint8;
        fun DarkGray() -> raylib::Color {
            return raylib::Color { .r = 130, .g = 130, .b = 130, .a = 255 };
        }
        fun Black() -> raylib::Color {
            return raylib::Color { .r = 0, .g = 0, .b = 0, .a = 255 };
        }
        fun Blue() -> raylib::Color {
            return raylib::Color { .r = 0, .g = 0, .b = 255, .a = 255 };
        }
        fun SkyBlue() -> raylib::Color {
            return raylib::Color { .r = 135, .g = 206, .b = 235, .a = 255 };
        }
        fun Red() -> raylib::Color {
            return raylib::Color { .r = 255, .g = 0, .b = 0, .a = 255 };
        }
        fun Green() -> raylib::Color {
            return raylib::Color { .r = 0, .g = 255, .b = 0, .a = 255 };
        }
        fun RayWhite() -> raylib::Color {
            return raylib::Color { .r = 245, .g = 245, .b = 245, .a = 255 };
        }
    }

